email:
  smtp_host: smtp.gmail.com
  smtp_port: 587
  smtp_user: your_email@gmail.com
  smtp_password: your_app_password  # Gmail app password — see README
  from_addr: your_email@gmail.com
  to_addrs:
    - your_email@gmail.com

search:
  queries:
    - "olson 911"
    - "olson 911se"
    - "ericson olson"
  filter_pattern: 'olson\s*911|911\s*se|911s[e\b]'

sources:
  web_search:
    enabled: true
    # backends: [duckduckgo, bing, google, yahoo]  # try in order, fallback on failure
    # queries:  # optional override
  searxng:
    enabled: true
    # instances:  # optional override — defaults to public SearXNG instances
  google_alerts:
    enabled: true
    feeds: []
    # Add your Google Alerts RSS feed URLs here. To set up:
    # 1. Go to google.com/alerts
    # 2. Create alerts for "olson 911se", "olson 911 se", etc.
    # 3. Set "Deliver to" → RSS feed
    # 4. Copy the RSS feed URLs here
  sailboatlistings:
    enabled: true
  craigslist:
    enabled: true
    regions:
      # PNW (priority)
      - seattle
      - portland
      - olympic
      - skagit
      - bellingham
      - eugene
      - corvallis
      - kpr        # Kennewick-Pasco-Richland
      - medford
      # California
      - sfbay
      - losangeles
      - sandiego
      - sacramento
      - santacruz
      - monterey
      - humboldt
      # East Coast
      - boston
      - newyork
      - longisland
      - newjersey
      - baltimore
      - annapolis
      - norfolk
      - charleston
      - savannah
      # Southeast / Gulf
      - miami
      - tampa
      - jacksonville
      - neworleans
      # Great Lakes / Midwest
      - chicago
      - detroit
      - milwaukee
      - cleveland
      # Other
      - honolulu
      - maine
      - newlondon
      - rhodeisland
      - delaware
  sailing_texas:
    enabled: true
  ericson_yachts:
    enabled: false  # 403 blocked, check manually
  sailboatowners:
    enabled: true
  fortyeight_north:
    enabled: true

rate_limit:
  delay_between_requests: 2.0

database:
  path: ./listings.db
